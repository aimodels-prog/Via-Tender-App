TENDER_FINAL_AI_SYNTHESIS=false
TENDER_EXTRACTION_CONCURRENCY=3
TENDER_EXTRACTION_PIPELINE_VERSION=field-complete-v1
TENDER_MAX_FILE_BYTES=262144000
