GEMINI_API_KEY=
DATABASE_URL=
PGSSL=true
PGSSL_REJECT_UNAUTHORIZED=false
JWT_SECRET=
ALLOWED_EMAIL_DOMAIN=via-int.com
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
PORTAL_ENTRY_URL=https://portal.via-int.com
PORTAL_HOME_URL=https://portal.via-int.com
PORTAL_SSO_SECRET=shared-secret-from-portal
PORTAL_SSO_ISSUER=via-portal
PORTAL_SSO_AUDIENCE=APP_SLUG_HERE
PORTAL_SSO_APP_SLUG=APP_SLUG_HERE
PORTAL_SSO_JWT_ALGORITHMS=HS256
DISABLE_VIA_STAFF_PASSWORD_LOGIN=true
EMERGENCY_ADMIN_LOGIN_ENABLED=true

# Tender extraction
TENDER_EXTRACTION_MODEL=gemini-3.1-pro-preview
TENDER_CLASSIFICATION_MODEL=gemini-3.5-flash
TENDER_EXTRACTION_CONCURRENCY=2
TENDER_PDF_SEGMENT_PAGES=25
TENDER_RELEVANCE_CONFIDENCE=0.85
TENDER_RELEVANCE_CONTEXT_PAGES=2
TENDER_FINAL_SYNTHESIS_MAX_CHARS=750000
TENDER_TABLE_CONTEXT_PAGES=80
TENDER_MAX_PAGES=2000
TENDER_MAX_FILE_BYTES=262144000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DELEGATED_USER_EMAIL=
GOOGLE_API_KEY=
